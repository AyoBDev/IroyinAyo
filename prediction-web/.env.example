# Copy this file to .env and fill in the real values before running `npm run build`.
# All VITE_* vars are inlined into the production bundle at build time — if any
# are missing, the app will throw on load.

VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Supabase Auth — frontend uses these to talk to GoTrue
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
