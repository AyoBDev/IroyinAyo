# Database
DATABASE_URL=postgres://user:password@localhost:5432/iroyinayo
DATABASE_URL_TEST=postgres://user:password@localhost:5432/iroyinayo_test

# Auth
JWT_SECRET=your-secret-key-here

# Server
PORT=3000

# CORS — comma-separated allowed origins (leave empty to allow all in development)
CORS_ORIGIN=http://localhost:3001

# WhatsApp Bot
ADMIN_NUMBERS=2348012345678,2348087654321
ENABLE_BOT=true

# AI Content Generation (Groq - runs Gemma model)
GROQ_API_KEY=your-groq-api-key-here
